# Backend selection
#   - "local" routes to LOCAL_LLM_BASE_URL (OpenAI-compatible)
# AGENT_LLM defaults to BACKEND_LLM if unset.
BACKEND_LLM=local
AGENT_LLM=local

# Local OpenAI-compatible endpoint (any server that speaks the OpenAI
# /v1/chat/completions schema — swapping backends only changes these vars).
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_API_KEY=not-needed
LOCAL_LLM_MODEL=google/gemma-4-26b-a4b
